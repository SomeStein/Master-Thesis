  author = {Morris, I.},
  year = 2011,
  journal = {Proceedings of the London Mathematical Society},
  volume = {107},
  pages = {null},
  doi = {10.1112/plms/pds080},
  abstract = {The joint spectral radius of a compact set of d\texttimes d matrices is defined to be the maximum possible exponential growth rate of products of matrices drawn from that set. In this article, we investigate the ergodic-theoretic structure of those sequences of matrices drawn from a given set whose products grow at the maximum possible rate. This leads to a notion of Mather set for matrix sequences, which is analogous to the Mather set in Lagrangian dynamics. We prove a structure theorem establishing the general properties of these Mather sets and describing the extent to which they characterise matrix sequences of maximum growth. We give applications of this theorem to the study of joint spectral radii and to the stability theory of discrete linear inclusions.},
  arxivid = {1109.4615},
  file = {/Users/aaronpumm/Zotero/storage/FEYKATFC/Morris - 2011 - Mather sets for sequences of matrices and applications to the study of joint spectral radii.pdf}
}

@article{1dd568fe33e6ff614e6bd3c981ef732c47a63799,
