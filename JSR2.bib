@article{e660125bdf4eb09557aa22bd33b1ae6360f24df5,
  title = {Rank One Matrices Do Not Contribute to the Failure of the Finiteness Property},
  author = {Morris, I.},
  year = 2011,
  journal = {arXiv: Spectral Theory},
  pages = {null},
  abstract = {The joint spectral radius of a bounded set of d times d real or complex matrices is defined to be the maximum exponential rate of growth of products of matrices drawn from that set. A set of matrices is said to satisfy the finiteness property if this maximum rate of growth occurs along a periodic infinite sequence. In this note we give some sufficient conditions for a finite set of matrices to satisfy the finiteness property in terms of its rank one elements. We show in particular that if a finite set of matrices does not satisfy the finiteness property, then the subset consisting of all matrices of rank at least two is nonempty, does not satisfy the finiteness property, and has the same joint spectral radius as the original set. We also obtain an exact formula for the joint spectral radii of sets of matrices which contain at most one element not of rank one, generalising a recent result of X. Dai.},
  arxivid = {1109.4648},
  file = {/Users/aaronpumm/Zotero/storage/RGKN79JT/Morris - 2011 - Rank one matrices do not contribute to the failure of the finiteness property.pdf}
}

